config.name.selectionBox.openConfig=Open Selection Box Config
config.comment.selectionBox.openConfig=Open this mod's ManyLib config screen.

config.name.selectionBox.enableBlockOutline=Enable Block Highlight
config.comment.selectionBox.enableBlockOutline=Render the custom selected block highlight.

config.name.selectionBox.enableEntityOutline=Enable Entity Highlight
config.comment.selectionBox.enableEntityOutline=Render the custom F3+B entity hitbox highlight.

config.name.selectionBox.entityHitboxRenderMode=Entity Hitbox Render Mode
config.comment.selectionBox.entityHitboxRenderMode=Render entity hitboxes before entities like old versions or after entity rendering like modern versions.
