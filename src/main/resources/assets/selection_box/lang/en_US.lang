config.comment.selectionBox.blockPreset=Preset style for block selection highlights. Custom uses the manual block settings below.
config.enum.selectionBox.blockPreset.CUSTOM=Custom
config.enum.selectionBox.blockPreset.CLASSIC_BLACK=Classic Black
config.enum.selectionBox.blockPreset.RED_BLUE=Red / Blue
config.enum.selectionBox.blockPreset.RAINBOW=Rainbow
config.enum.selectionBox.blockPreset.LOW_ALPHA=Low Alpha
config.enum.selectionBox.blockPreset.BOLD=Bold

